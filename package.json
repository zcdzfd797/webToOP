{
  "name": "html-to-video",
  "version": "1.0.0",
  "description": "Render HTML to MP4 video at 1080p (1920x1080, 16:9)",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "html-to-video": "src/index.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "stop": "powershell -Command \"Stop-Process -Id (Get-NetTCPConnection -LocalPort 3456).OwningProcess -Force -ErrorAction SilentlyContinue; Write-Output 'Server stopped'\"",
    "cli": "node src/index.js --config config.json",
    "example": "node src/index.js --input templates/example.html --output output/video.mp4 --duration 5 --fps 30",
    "sanlian": "node src/index.js --config config.json",
    "build": "node src/index.js --config config.json"
  },
  "keywords": [
    "html",
    "video",
    "mp4",
    "puppeteer",
    "ffmpeg"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "puppeteer": "^25.1.0"
  }
}
